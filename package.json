{
  "name": "openpx",
  "module": "src/app/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/app/main.ts",
    "eval:core": "bun run eval:suite --suite core-eval-suite --baseline-root-dir eval-baselines",
    "eval:real": "bun run src/real-eval/run-suite.ts",
    "eval:review": "bun run src/eval/run-review.ts",
    "eval:suite": "bun run src/eval/run-suite.ts",
    "smoke:planner": "bun run src/app/smoke-planner.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "validation:run": "bun run src/validation/run-suite.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ink-testing-library": "^1.0.4",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.4.1",
    "ink": "^6.8.0",
    "ink-markdown": "^1.0.4",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
